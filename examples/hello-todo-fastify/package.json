{
  "name": "hello-todo-fastify",
  "version": "0.1.0",
  "description": "A minimal todo-list HTTP API built with Fastify and hexagonal architecture.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/swagger": "9.7.0",
    "fastify": "5.8.5",
    "fastify-type-provider-zod": "6.1.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "uuid": "11.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.8.0",
    "@types/uuid": "10.0.0",
    "tsx": "4.22.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
