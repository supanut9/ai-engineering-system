root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.go]
indent_style = tab

[Makefile]
indent_style = tab

[*.md]
# Preserve intentional trailing spaces used for hard line breaks in Markdown.
trim_trailing_whitespace = false
